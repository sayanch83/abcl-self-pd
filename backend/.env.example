# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRES_IN=8h

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=./data/abcl_pd.db

# ── Twilio ────────────────────────────────────────────────────────────────────
# All three are required for real SMS. Without them the app runs in simulation mode.

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# For OTP — Twilio Verify Service SID (starts with VA...)
# Create at: console.twilio.com → Explore Products → Verify → Create Service
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For PD link SMS — use ONE of the two options below:
#
# Option A: Messaging Service SID (starts with MG...) — RECOMMENDED
# Bypasses A2P 10DLC number block on trial accounts.
# Create at: console.twilio.com → Messaging → Services → Create Messaging Service
# Add your phone number (+19785612764) as a sender inside the service.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B: Direct phone number — only works if A2P registration is complete
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Demo mobile numbers (must be Twilio-verified for trial accounts) ──────────
DEMO_MOBILE_1=9XXXXXXXXX
DEMO_MOBILE_2=9XXXXXXXXX
DEMO_MOBILE_3=9XXXXXXXXX
DEMO_MOBILE_4=9XXXXXXXXX
DEMO_MOBILE_5=9XXXXXXXXX

# ── Cloudinary (optional — placeholder images used in demo without it) ────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OTP settings ──────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
LINK_EXPIRY_HOURS=24
